FROM node:22-alpine

WORKDIR /app

# Install dependencies first for caching
COPY package.json package-lock.json ./
# Use --no-audit for speed and clean terminal
RUN npm install --no-audit

# Copy everything for initial setup (overshadowed by volume at runtime)
COPY . .

# In development, we run as root inside the container to avoid UID mismatch errors (EACCES)
# but we drop all Linux capabilities in the docker-compose.yml for high security.
USER root

# Expose Vite dev server port
EXPOSE 3000

# Run in dev mode with host=0.0.0.0
CMD ["npm", "run", "dev", "--", "--host"]
